{
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "routes": [
    {
      "src": "/css/(.*)",
      "methods": ["GET"],
      "headers": {
        "Cache-Control": "public, max-age=604800"
      },
      "continue": true
    },
    {
      "src": "/js/(.*)",
      "methods": ["GET"],
      "headers": {
        "Cache-Control": "public, max-age=604800"
      },
      "continue": true
    },
    {
      "src": "/images/(.*)",
      "methods": ["GET"],
      "headers": {
        "Cache-Control": "public, max-age=604800"
      },
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "/api"
    }
  ]
}